# --- IBM Quantum (Qiskit Runtime) -------------------------------------------
# Create an API key at https://quantum.ibm.com/ (dashboard → API token).
# Use the same 44-character token for both variables below if your tooling expects either name.

IBM_Q_TOKEN=your_ibm_quantum_token_here
IBM_QUANTUM_TOKEN=your_ibm_quantum_token_here

# Optional: instance CRN from IBM Quantum → Instances (hover CRN → copy).
# Leave unset to use your account default (typical for Open Plan). Set when docs require a specific instance.
# IBM_QUANTUM_INSTANCE=crn:v1:bluemix:public:quantum-computing:...

# Optional: almost always ibm_quantum_platform (default in config/quantum_config.yaml).
# IBM_QUANTUM_CHANNEL=ibm_quantum_platform

# Optional: default real-device backend when using config/quantum_config_hardware.yaml
# IBM_BACKEND=ibm_torino

# Ensure Python resolves project modules
PYTHONPATH=.
