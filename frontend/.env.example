# Copy to `.env.local` for local overrides (see https://nextjs.org/docs/app/building-your-application/configuring/environment-variables)

# FastAPI base URL (no trailing slash). Repo default dev API is 8780 (see scripts/dev_stack.sh).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8780

# Next server-side API origin used by rewrites and the governed /api/proxy route.
API_ORIGIN=http://127.0.0.1:8780

# Clerk auth. Leave blank in local dev to run the UI in auth-bypass mode.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Use the governed same-origin Next proxy for browser API calls by default.
# Set to 0 only for local debugging against FastAPI directly.
NEXT_PUBLIC_USE_API_PROXY=1

# Local role fallback when Clerk role metadata is not configured.
DEV_ADMIN_EMAILS=
DEV_REVIEWER_EMAILS=

# Shared secret forwarded from Next /api/proxy to FastAPI when internal auth is enabled.
QGG_INTERNAL_API_SECRET=dev-internal-secret

# Local performance/reliability controls.
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_API_TIMEOUT_MS=15000
NEXT_PUBLIC_API_RETRY_COUNT=1
NEXT_PUBLIC_API_CACHE_TTL_MS=15000
